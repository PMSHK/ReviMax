<Window x:Class="ReviMax.NumeratorManager.UI.Windows.NumeratorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ReviMax.NumeratorManager.UI.Windows"
        xmlns:materialDesign ="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:orderConverter ="clr-namespace:ReviMax.UI.Converters"
        mc:Ignorable="d"
        Title="Найстройка обозначения" Height="450" Width="500">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>



                <ResourceDictionary Source="/ReviMax;component/UI/Resources/WindowElementsResource.xaml"/>
                <ResourceDictionary Source="/ReviMax;component/UI/Templates/GeneralButtonStyle.xaml"/>
                <ResourceDictionary Source="/ReviMax;component/UI/Templates/RmListStyle.xaml"/>
                <ResourceDictionary Source="/ReviMax;component/UI/Templates/LineItemTemplate.xaml"/>

                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Defaults.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignColors;component/Themes/Recommended/Primary/MaterialDesignColor.Blue.xaml"/>

                <!--<materialDesign:BundledTheme BaseTheme="Dark" 
                                        PrimaryColor="Blue" 
                                        SecondaryColor="Lime" />-->

            </ResourceDictionary.MergedDictionaries>
            <orderConverter:OrderToBoolConverter x:Key="OrderConverter"/>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="{StaticResource Bg}" >
        <Grid Margin= "{StaticResource WindowMargin}" >
            <Border CornerRadius="{StaticResource WindowCornerRadius}" Background="{StaticResource Panel}" BorderThickness="{DynamicResource StandardBorderThickness}" BorderBrush="{StaticResource Border}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <Button Style="{StaticResource RmButton}" Width="Auto" Height="Auto" Margin="{StaticResource AllSidesMargin}" Content="Выбрать элементы" ToolTip="Позволяет выбрать элементы для обработки в модели Revit" Command="{Binding SelectElements}"/>

                        <RadioButton Margin="{StaticResource AllSidesMargin}" Content="Относительно X" Foreground="{StaticResource Text}" IsChecked="{Binding CurrentOrder, Mode=TwoWay, Converter={StaticResource OrderConverter}, ConverterParameter=X}"/>
                        <RadioButton Margin="{StaticResource AllSidesMargin}" Content="Относительно Y" Foreground="{StaticResource Text}" IsChecked="{Binding CurrentOrder, Mode=TwoWay, Converter={StaticResource OrderConverter}, ConverterParameter=Y}"/>
                        <TextBox Style="{StaticResource MaterialDesignTextBox}" materialDesign:HintAssist.Hint="Префикс" materialDesign:HintAssist.Foreground="{StaticResource Text}" Foreground="{StaticResource Text}" Margin="{StaticResource AllSidesMargin}" Text="{Binding Prefix}"  Height="25" />
                        <TextBox Style="{StaticResource MaterialDesignTextBox}" materialDesign:HintAssist.Hint="Основной текст" materialDesign:HintAssist.Foreground="{StaticResource Text}" Foreground="{StaticResource Text}" Margin="{StaticResource AllSidesMargin}" Text="{Binding GeneralText}" SelectedText="Основной текст"></TextBox>
                        <TextBox Style="{StaticResource MaterialDesignTextBox}" materialDesign:HintAssist.Hint="Суффикс" materialDesign:HintAssist.Foreground="{StaticResource Text}" Foreground="{StaticResource Text}" Margin="{StaticResource AllSidesMargin}" Text="{Binding Suffix}" SelectedText="Суффикс"></TextBox>
                        <TextBox Style="{StaticResource MaterialDesignTextBox}" materialDesign:HintAssist.Hint="Разделитель" materialDesign:HintAssist.Foreground="{StaticResource Text}" Foreground="{StaticResource Text}" Margin="{StaticResource AllSidesMargin}" Text="{Binding Separator}" SelectedText="Суффикс"></TextBox>
                        <TextBox Style="{StaticResource MaterialDesignTextBox}" materialDesign:HintAssist.Hint="Шаг" materialDesign:HintAssist.Foreground="{StaticResource Text}" Foreground="{StaticResource Text}" Margin="{StaticResource AllSidesMargin}" Text="{Binding Step}" SelectedText="Суффикс"></TextBox>
                        <Button Style="{StaticResource RmButton}" Width="Auto" Height="Auto" Margin="{StaticResource AllSidesMargin}" Content="Переименовать" ToolTip="Переименовывает все выбранные объекты модели Revit согласно указанным параметрам" Command="{Binding RenameElements}"/>
                    </StackPanel>
                    <Border Grid.Column="1" BorderThickness="{StaticResource StandardBorderThickness}" BorderBrush="{StaticResource Border}" CornerRadius="{StaticResource WindowCornerRadius}">
                        <ListBox Width="275" HorizontalAlignment="Center"
                                 Background="Transparent" BorderThickness="0" ItemContainerStyle="{StaticResource RmListItem}"
                                 ItemTemplate="{StaticResource LineItemTemplate}"
                                 ItemsSource="{Binding Parameters}"
                                 SelectedItem="{Binding SelectedParameter, Mode=TwoWay}">   
                        </ListBox>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
