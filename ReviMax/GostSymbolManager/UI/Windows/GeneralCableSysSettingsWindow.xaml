<Window x:Class="ReviMax.UI.Windows.GeneralCableSysSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ReviMax.GostSymbolManager.UI.Windows"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        mc:Ignorable="d"
        Title="General cable system settings" Height="450" Width="500">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- путь: /ТвояСборка;component/папка/файл.xaml -->
                <ResourceDictionary Source="/ReviMax;component/GostSymbolManager/UI/UserControl/Resources/RmIconButtonStyle.xaml"/>
                <ResourceDictionary Source="/ReviMax;component/GostSymbolManager/UI/UserControl/Resources/GeneralButtonStyle.xaml"/>
                <ResourceDictionary Source="/ReviMax;component/GostSymbolManager/UI/UserControl/Resources/RedButtonStyle.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <!-- Цвета -->
            <SolidColorBrush x:Key="Bg" Color="#1F1F1F"/>
            <SolidColorBrush x:Key="Panel" Color="#262626"/>
            <SolidColorBrush x:Key="Panel2" Color="#2B2B2B"/>
            <SolidColorBrush x:Key="Border" Color="#3A3A3A"/>
            <SolidColorBrush x:Key="Text" Color="#EAEAEA"/>
            <SolidColorBrush x:Key="TextDim" Color="#BDBDBD"/>
            <SolidColorBrush x:Key="Accent" Color="#4EA1FF"/>
            <SolidColorBrush x:Key="Danger" Color="#FF5A5A"/>
        </ResourceDictionary>
    </Window.Resources>
        <Grid Background="{StaticResource Bg}">
        <Grid Margin="12">
            <Border Background="{StaticResource Panel}" CornerRadius="16" BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="12">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Grid.Column="0" Orientation="Vertical" VerticalAlignment="Top" >
                        <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource Text}" Margin="0,0,6,12" Text="Общие настройки:"/>
                        <Separator Margin="0,0,0,12" BorderThickness="2" BorderBrush="{StaticResource Border}"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="380"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Text}" Margin="0,0,6,0" Text="Привязка (сетка), мм:" ToolTip="Минимальное расстояние между позициями символов. Символы могут быть размещены только в узлах этой сетки.\n Меньшее значение = больше точность, большее значение = меньше символов."/>
                            <TextBox Grid.Column="1" Width="50" Margin="12,0,0,0" Background="{StaticResource Panel2}" BorderBrush="{StaticResource Border}" BorderThickness="1" Foreground="{StaticResource Text}" Padding="3"/>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="380"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Text}" Margin="0,0,6,0" Text="Минимальное расстояние между символами, мм:" ToolTip="Запрещает размещение символов ближе этого расстояния друг к другу. \nПредотвращает наложение/скопление символов."/>
                            <TextBox Grid.Column="1" Width="50" Margin="12,0,0,0" Background="{StaticResource Panel2}" BorderBrush="{StaticResource Border}" BorderThickness="1" Foreground="{StaticResource Text}" Padding="3"/>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="380"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Text}" Margin="0,0,6,0" Text="Отступ от разветвителей, мм:" ToolTip="Запретная зона вокруг узлов разветвления кабельных трасс. Символы не размещаются ближе этого расстояния к точкам соединения 3+ линий."/>
                            <TextBox Grid.Column="1" Width="50" Margin="12,0,0,0" Background="{StaticResource Panel2}" BorderBrush="{StaticResource Border}" BorderThickness="1" Foreground="{StaticResource Text}" Padding="3"/>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="380"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Text}" Margin="0,0,6,0" Text="Отступ от углов поворота:" ToolTip="Запретная зона вокруг углов поворота трассы. Символы не размещаются вблизи изгибов кабельных линий."/>
                            <TextBox Grid.Column="1" Width="50" Margin="12,0,0,0" Background="{StaticResource Panel2}" BorderBrush="{StaticResource Border}" BorderThickness="1" Foreground="{StaticResource Text}" Padding="3"/>
                        </Grid>
                        
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                        <Button Style="{StaticResource RmButton}" Width="45" Height="45" >
                            <fa:ImageAwesome Icon="Check" Width="18" Height="18" Foreground="{StaticResource Text}"/>
                        </Button>
                        <Button Style="{StaticResource RmRedButton}" Width="45" Height="45" Background="#3A2323" BorderBrush="{StaticResource Danger}">
                            <fa:ImageAwesome Icon="Close" Width="18" Height="18" Foreground="{StaticResource Text}"/>
                        </Button>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
