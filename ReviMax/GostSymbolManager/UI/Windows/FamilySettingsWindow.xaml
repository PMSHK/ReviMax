<Window x:Class="ReviMax.UI.Windows.FamilySettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ReviMax.UI.Windows"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        xmlns:converter="clr-namespace:ReviMax.GostSymbolManager.UI.Converters"
        mc:Ignorable="d"
        Title="Найстройка семейства" Height="450" Width="500">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- путь: /ТвояСборка;component/папка/файл.xaml -->
                <ResourceDictionary Source="/ReviMax;component/GostSymbolManager/UI/UserControl/Resources/RmIconButtonStyle.xaml"/>
                <ResourceDictionary Source="/ReviMax;component/GostSymbolManager/UI/UserControl/Resources/GeneralButtonStyle.xaml"/>
                <ResourceDictionary Source="/ReviMax;component/GostSymbolManager/UI/UserControl/Resources/RedButtonStyle.xaml"/>
                <ResourceDictionary Source="/ReviMax;component/GostSymbolManager/UI/UserControl/Resources/RmListStyle.xaml"/>
                <ResourceDictionary Source="/ReviMax;component/GostSymbolManager/UI/UserControl/Resources/RmRadioButtonNoBorderStyle.xaml"/>
                <ResourceDictionary Source="/ReviMax;component/GostSymbolManager/UI/UserControl/Resources/FamilyItemTemplate.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!--<converter:BoolToIconConverter x:Key="BoolToIconConverter"/>-->

            <!-- Цвета -->
            <SolidColorBrush x:Key="Bg" Color="#1F1F1F"/>
            <SolidColorBrush x:Key="Panel" Color="#262626"/>
            <SolidColorBrush x:Key="Panel2" Color="#2B2B2B"/>
            <SolidColorBrush x:Key="Border" Color="#3A3A3A"/>
            <SolidColorBrush x:Key="Text" Color="#EAEAEA"/>
            <SolidColorBrush x:Key="TextDim" Color="#BDBDBD"/>
            <SolidColorBrush x:Key="Accent" Color="#4EA1FF"/>
            <SolidColorBrush x:Key="Danger" Color="#FF5A5A"/>
        </ResourceDictionary>
        
    </Window.Resources>
    <Grid Background="{StaticResource Bg}">
        <Grid Margin="12">
            <Border Background="{StaticResource Panel}" CornerRadius="16" BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="12">
                <DockPanel>
                    <Border DockPanel.Dock="Left" Background="Transparent" BorderThickness="2" CornerRadius="16" BorderBrush="{StaticResource Border}">
                        <ListBox DockPanel.Dock="Left" Width="280" HorizontalAlignment="Center"
                             Background="Transparent" BorderThickness="0" ItemContainerStyle="{StaticResource RmListItem}"
                             ItemTemplate="{StaticResource FamilyItemTemplate}"
                                 Margin="8"
                                 ItemsSource="{Binding FamilySet}"
                                 SelectedItem="{Binding SelectedFamily}">

                        </ListBox>
                    </Border>
                    <Grid DockPanel.Dock="Right">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="320"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Vertical" Margin="6,0,0,12">
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="75"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Text}" Margin="0,0,6,0" Text="Шаг, мм:" ToolTip="Шаг между символами"/>
                                <TextBox Grid.Column="1" Width="50" Margin="12,0,0,0" Background="{StaticResource Panel2}" BorderBrush="{StaticResource Border}" BorderThickness="1" Foreground="{StaticResource Text}" Padding="3"
                                         Text="{Binding StepValue,Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="75"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Text}" Margin="0,0,6,0" Text="Отступ, мм:" ToolTip="Отступ символа от оси"/>
                                <TextBox Grid.Column="1" Width="50" Margin="12,0,0,0" Background="{StaticResource Panel2}" BorderBrush="{StaticResource Border}" BorderThickness="1" Foreground="{StaticResource Text}" Padding="3"
                                         Text="{Binding OffsetValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="75"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Text}" Margin="0,0,6,0" Text="Размер, мм:" ToolTip="Размер символа"/>
                                <TextBox Grid.Column="1" Width="50" Margin="12,0,0,0" Background="{StaticResource Panel2}" BorderBrush="{StaticResource Border}" BorderThickness="1" Foreground="{StaticResource Text}" Padding="3"
             Text="{Binding GlyphSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>

                        </StackPanel>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="12,0,0,0">
                            <Button Style="{StaticResource RmButton}" Width="40" Height="40" Command="{Binding Accept}">
                                <fa:ImageAwesome Icon="Check" Width="15" Height="15" Foreground="{StaticResource Text}"/>
                            </Button>
                            <Button Style="{StaticResource RmRedButton}" Width="40" Height="40" Background="#3A2323" BorderBrush="{StaticResource Danger}" Command="{Binding Decline}">
                                <fa:ImageAwesome Icon="Close" Width="15" Height="15" Foreground="{StaticResource Text}"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
