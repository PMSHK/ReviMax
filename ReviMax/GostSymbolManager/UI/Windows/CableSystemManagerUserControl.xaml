<UserControl x:Class="ReviMax.GostSymbolManager.UI.Windows.CableSystemManagerUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converter="clr-namespace:ReviMax.GostSymbolManager.UI.Converters"
             mc:Ignorable="d"
             d:DesignHeight="520" d:DesignWidth="920">

    <!-- ========= Ресурсы (цвета + стили) ========= -->
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- путь: /ТвояСборка;component/папка/файл.xaml -->
                <ResourceDictionary Source="/ReviMax;component/GostSymbolManager/UI/UserControl/Resources/RmIconButtonStyle.xaml"/>
                <ResourceDictionary Source="/ReviMax;component/GostSymbolManager/UI/UserControl/Resources/GeneralButtonStyle.xaml"/>
                <ResourceDictionary Source="/ReviMax;component/GostSymbolManager/UI/UserControl/Resources/RedButtonStyle.xaml"/>
                <ResourceDictionary Source="/ReviMax;component/GostSymbolManager/UI/UserControl/Resources/RmListStyle.xaml"/>
                <ResourceDictionary Source="/ReviMax;component/GostSymbolManager/UI/UserControl/Resources/RmRadioButtonStyle.xaml"/>
                <ResourceDictionary Source="/ReviMax;component/GostSymbolManager/UI/UserControl/Resources/CableSystemsElementPanelTemplate.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <converter:EnumToBoolConverter x:Key="EnumToBool"/>
            <!--<converter:EnumToBoolConverter x:Key="EnumToBool"/>-->
            <!-- Цвета -->
            <SolidColorBrush x:Key="Bg" Color="#1F1F1F"/>
            <SolidColorBrush x:Key="Panel" Color="#262626"/>
            <SolidColorBrush x:Key="Panel2" Color="#2B2B2B"/>
            <SolidColorBrush x:Key="Border" Color="#3A3A3A"/>
            <SolidColorBrush x:Key="Text" Color="#EAEAEA"/>
            <SolidColorBrush x:Key="TextDim" Color="#BDBDBD"/>
            <SolidColorBrush x:Key="Accent" Color="#4EA1FF"/>
            <SolidColorBrush x:Key="Danger" Color="#FF5A5A"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <!-- ========= Разметка ========= -->
    <Grid Background="{StaticResource Bg}">
        <Grid Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая панель -->
            <Border Grid.Column="0" Background="{StaticResource Panel}" CornerRadius="16"
                    BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="12">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource Text}"
                               Text="Оборудование" Margin="4,2,4,10"/>

                    <StackPanel>
                        <RadioButton Style="{StaticResource RmRadio}" Content="Все" IsChecked="{Binding CurrentFilterMode, Mode=TwoWay, Converter={StaticResource EnumToBool}, ConverterParameter=ALL}"/>
                        <RadioButton Style="{StaticResource RmRadio}" Content="Лотки" IsChecked="{Binding CurrentFilterMode, Mode=TwoWay, Converter={StaticResource EnumToBool}, ConverterParameter=TRAYS}"/>
                        <RadioButton Style="{StaticResource RmRadio}" Content="Трубы" IsChecked="{Binding CurrentFilterMode, Mode=TwoWay, Converter={StaticResource EnumToBool}, ConverterParameter=CONDUITS}"/>
                        <RadioButton Style="{StaticResource RmRadio}" Content="Выбрать на виде" IsChecked="{Binding CurrentFilterMode, Mode=TwoWay, Converter={StaticResource EnumToBool}, ConverterParameter=SELECTED}"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Правая панель -->
            <Border Grid.Column="2" Background="{StaticResource Panel}" CornerRadius="16"
                    BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Верх: заголовок + поиск -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="240"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock VerticalAlignment="Center"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource Text}"
                                   Text="Элементы на виде"/>

                        <TextBox Grid.Column="1" Height="34"
                                 VerticalContentAlignment="Center"
                                 Foreground="{StaticResource Text}"
                                 Background="{StaticResource Panel2}"
                                 BorderBrush="{StaticResource Border}"
                                 BorderThickness="1"
                                 Padding="10,0"
                                 Text="Поиск (позже привяжем)"/>
                    </Grid>


                    <ListBox x:Name="CableSystemList"
                        Grid.Row="2"
         Background="Transparent"
         BorderThickness="0"
         ItemContainerStyle="{StaticResource RmListItem}"
         ItemTemplate="{StaticResource CableSystemItemElement}"
         ItemsSource="{Binding Systems}"
                             >
                    </ListBox>

                    <!-- Низ: кнопки действий -->
                    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">

                        <Button Style="{StaticResource RmButton}" Content="Сохранить настройки" Command="{Binding SaveSettings}"/>
                        <Button Style="{StaticResource RmButton}" Content="Разместить" Command="{Binding PlaceGostAnnotations}"/>
                        <Button Style="{StaticResource RmButton}" Content="Перерисовать" Command="{Binding RedrawGostAnnotations}"/>
                        <Button Style="{StaticResource RmRedButton}" Content="Удалить" Background="#3A2323" BorderBrush="#6B2D2D" Command="{Binding DeleteGostAnnotations}"/>

                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
