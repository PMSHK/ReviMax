<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys ="clr-namespace:System;assembly=mscorlib">

    <Thickness x:Key="WindowMargin">12</Thickness>
    <Thickness x:Key="AllSidesMargin">10,10,10,10</Thickness>
    <Thickness x:Key="LeftMargin">10,0,0,0</Thickness>
    <Thickness x:Key="TopMargin">0,10,0,0</Thickness>
    <Thickness x:Key="RightMargin">0,0,10,0</Thickness>
    <Thickness x:Key="BotMargin">0,0,0,10</Thickness>
    <Thickness x:Key="StandardBorderThickness">1</Thickness>
    <Thickness x:Key="StandardBorderPadding">12</Thickness>

    <!-- Цвета -->
    <SolidColorBrush x:Key="Bg" Color="#1F1F1F"/>
    <SolidColorBrush x:Key="Panel" Color="#262626"/>
    <SolidColorBrush x:Key="Panel2" Color="#2B2B2B"/>
    <SolidColorBrush x:Key="Border" Color="#3A3A3A"/>
    <SolidColorBrush x:Key="Text" Color="#EAEAEA"/>
    <SolidColorBrush x:Key="TextDim" Color="#BDBDBD"/>
    <SolidColorBrush x:Key="Accent" Color="#4EA1FF"/>
    <SolidColorBrush x:Key="Danger" Color="#FF5A5A"/>
    <!-- Значения -->
    <CornerRadius x:Key ="WindowCornerRadius">12</CornerRadius>
    <CornerRadius x:Key ="ButtonCornerRadius">8</CornerRadius>

    <ResourceDictionary.MergedDictionaries>
        <!-- путь: /ТвояСборка;component/папка/файл.xaml -->
        <ResourceDictionary Source="/ReviMax;component/UI/Templates/RmIconButtonStyle.xaml"/>
        <!--<ResourceDictionary Source="/ReviMax;component/UI/Templates/GeneralButtonStyle.xaml"/>-->
        <ResourceDictionary Source="/ReviMax;component/UI/Templates/RedButtonStyle.xaml"/>
        <ResourceDictionary Source="/ReviMax;component/UI/Templates/RmListStyle.xaml"/>
        <ResourceDictionary Source="/ReviMax;component/UI/Templates/RmRadioButtonNoBorderStyle.xaml"/>
        <ResourceDictionary Source="/ReviMax;component/UI/Templates/LineItemTemplate.xaml"/>
    </ResourceDictionary.MergedDictionaries>

</ResourceDictionary>