<Window x:Class="ReviMax.UI.Windows.ReviLineSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ReviMax.UI.Windows"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        mc:Ignorable="d"
        Title="Найстройка обозначения" Height="450" Width="500">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- путь: /ТвояСборка;component/папка/файл.xaml -->
                <ResourceDictionary Source="/ReviMax;component/UI/UserControl/Resources/RmIconButtonStyle.xaml"/>
                <ResourceDictionary Source="/ReviMax;component/UI/UserControl/Resources/GeneralButtonStyle.xaml"/>
                <ResourceDictionary Source="/ReviMax;component/UI/UserControl/Resources/RedButtonStyle.xaml"/>
                <ResourceDictionary Source="/ReviMax;component/UI/UserControl/Resources/RmListStyle.xaml"/>
                <ResourceDictionary Source="/ReviMax;component/UI/UserControl/Resources/RmRadioButtonNoBorderStyle.xaml"/>
                <ResourceDictionary Source="/ReviMax;component/UI/UserControl/Resources/LineItemTemplate.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <!-- Цвета -->
            <SolidColorBrush x:Key="Bg" Color="#1F1F1F"/>
            <SolidColorBrush x:Key="Panel" Color="#262626"/>
            <SolidColorBrush x:Key="Panel2" Color="#2B2B2B"/>
            <SolidColorBrush x:Key="Border" Color="#3A3A3A"/>
            <SolidColorBrush x:Key="Text" Color="#EAEAEA"/>
            <SolidColorBrush x:Key="TextDim" Color="#BDBDBD"/>
            <SolidColorBrush x:Key="Accent" Color="#4EA1FF"/>
            <SolidColorBrush x:Key="Danger" Color="#FF5A5A"/>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Background="{StaticResource Bg}">
        <Grid Margin="12">
            <Border Background="{StaticResource Panel}" CornerRadius="16" BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="12">
                <DockPanel>
                    <Grid DockPanel.Dock="Left">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="22"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                    <Border Grid.Column="2" Background="Transparent" BorderThickness="2" CornerRadius="16" BorderBrush="{StaticResource Border}">
                            <ListBox Width="275" HorizontalAlignment="Center" Margin="8"
                                 Background="Transparent" BorderThickness="0" ItemContainerStyle="{StaticResource RmListItem}"
                                 ItemTemplate="{StaticResource LineItemTemplate}"
                                     ItemsSource="{Binding LineStyles}"
                                     SelectedItem="{Binding SelectedLineStyle, Mode=TwoWay}">    

                            </ListBox>
                        </Border>
                    

                        <StackPanel Grid.Column="0">
                            <Button Style="{StaticResource RmIconButton}" Width="20" Height="20" Margin="0,0,2,5" Command="{Binding EditSettings}">
                                <fa:ImageAwesome Icon="Cog" Width="20" Height="20" Foreground="{StaticResource Text}"/>
                            </Button>
                        </StackPanel>

                    </Grid>
                    <Grid DockPanel.Dock="Right">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="320"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Vertical">
                            <Button Style="{StaticResource RmButton}" Width="Auto" Height="Auto" Margin="8,0,0,8" Content="Загрузить" ToolTip="Позволяет загрузить общие настройки линий, семейств, параметров разброса" Command="{Binding LoadSettings}"/>
                            <Button Style="{StaticResource RmButton}" Width="Auto" Height="Auto" Margin="8,0,0,8" Content="Сохранить" ToolTip="Позволяет сохранить общие настройки линий, семейств, параметров разброса" Command="{Binding SaveSettings}"/>
                            <Button Style="{StaticResource RmButton}" Width="Auto" Height="Auto" Margin="8,0,0,8" Content="Загрузить линию" ToolTip="Позволяет загрузить тип линий" Command="{Binding LoadLineTypes}"/>
                            <Button Style="{StaticResource RmButton}" Width="Auto" Height="Auto" Margin="8,0,0,8" Content="Символ" ToolTip="Позволяет работать с аннотационными семействами ReviMax" Command="{Binding EditLineSymbol}"/>
                           


                        </StackPanel>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="12,0,0,0">
                            <Button Style="{StaticResource RmButton}" Width="45" Height="45" Margin="0,0,10,0" Command="{Binding Accept}">
                                <fa:ImageAwesome Icon="Check" Width="20" Height="20" Foreground="{StaticResource Text}"/>
                            </Button>
                            <Button Style="{StaticResource RmRedButton}" Width="45" Height="45" Margin="0,0,0,0" Background="#3A2323" BorderBrush="{StaticResource Danger}" Command="{Binding Decline}">
                                <fa:ImageAwesome Icon="Close" Width="20" Height="20" Foreground="{StaticResource Text}"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </DockPanel>
            </Border>
        </Grid>
        <ComboBox HorizontalAlignment="Left" Margin="811,217,0,0" VerticalAlignment="Top" Width="120"/>
    </Grid>
</Window>
